gitignore
# ============================================
# REPORTS GENERATED BY THE SCRIPT (CONTAIN SYSTEM DATA - DO NOT SHARE!)
# ============================================
windows_security_report.json
windows_security_report.html
*.json
*.html

# ============================================
# TEMPORARY FILES CREATED DURING RUNTIME
# ============================================
*.tmp
*.tsv
*.log
*.temp
*.bak
*.old
*.swp
*.swo

# ============================================
# WINDOWS SYSTEM FILES
# ============================================
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.DS_Store

# ============================================
# SENSITIVE / CONFIGURATION FILES
# ============================================
*.p12
*.pfx
*.cer
*.crt
*.key
*.pem
*.rdp
*.ps1user
*.secret
*.credential
*.encrypted

# ============================================
# EDITOR / IDE SETTINGS
# ============================================
.vscode/
.idea/
*.code-workspace
*.sln
*.suo
*.user
*.userprefs

# ============================================
# TEST FILES (if you use them)
# ============================================
test*.ps1
temp_*
sample_*

# ============================================
# EXAMPLE REPORTS FOLDER (uncomment if you want to keep examples)
# ============================================
# !examples/
# !examples/windows_security_report.html
# !examples/windows_security_report.json
